PORT=3000
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Supabase (service role key — nunca expor no frontend)
# Obtenha em: Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# IA — escolha um provedor e informe a chave
# AI_PROVIDER aceita: openai | gemini | anthropic
AI_PROVIDER=gemini
AI_API_KEY=
# AI_MODEL=gemini-1.5-flash  # opcional; padrão: openai=gpt-4o-mini, gemini=gemini-1.5-flash, anthropic=claude-3-haiku-20240307

# Token para proteger os endpoints /status e /qr (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BOT_ADMIN_TOKEN=
