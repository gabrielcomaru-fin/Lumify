# ==============================================================
# Lumify App — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositório.
# ==============================================================

# ──────────────────────────────────────────────────────────────
# Supabase (obrigatórias)
# Obtenha em: https://supabase.com → Project Settings → API
# ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ──────────────────────────────────────────────────────────────
# Aplicação (opcionais — os padrões já funcionam)
# ──────────────────────────────────────────────────────────────
VITE_APP_NAME=Lumify
VITE_APP_VERSION=1.0.0

# URL base usada nos links de redirecionamento de auth (ex.: reset de senha).
# Desenvolvimento: http://localhost:5173
# Produção:        https://lumify.app.br
VITE_REDIRECT_URL_BASE=http://localhost:5173

# Base path do Vite. Use '/' para domínio raiz ou '/app/' para subpath.
VITE_BASE_PATH=/

# ──────────────────────────────────────────────────────────────
# Stripe — usadas APENAS pelo servidor (Vercel Functions / api/)
# Nunca exponha STRIPE_SECRET_KEY ou STRIPE_WEBHOOK_SECRET no cliente.
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MENSAL=price_...
STRIPE_PRICE_PREMIUM_MENSAL=price_...

# Supabase Service Role — usada APENAS pelo servidor (webhook, checkout)
# Obtenha em: Project Settings → API → service_role key
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
