# Template de variaveis de ambiente - copie para .env e preencha os valores.
# Para trocar de hospedagem: preencha o .env e importe/cole em lote no painel do host.

# Configuracao do Supabase - NovaFin
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Configuracao do Stripe
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MENSAL=
STRIPE_PRICE_PREMIUM_MENSAL=

# Supabase Server (service role para webhook)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Configuracao do App
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development
VITE_REDIRECT_URL_BASE=
VITE_BASE_PATH=/
VITE_APP_NAME=Lumify
